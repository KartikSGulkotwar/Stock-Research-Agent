{
  "name": "stock-research-agent",
  "version": "1.0.0",
  "description": "AI-powered multi-agent stock research system using Elasticsearch",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "setup": "tsx src/setup-indexes.ts",
    "install:all": "npm install && cd api-server && npm install && cd ../frontend && npm install",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev:frontend\"",
    "dev:api": "tsx api-server/src/server.ts",
    "dev:frontend": "cd frontend && npm run dev"
  },
  "keywords": ["elasticsearch", "ai", "stocks", "multi-agent", "hackathon"],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@elastic/elasticsearch": "^8.12.0",
    "@anthropic-ai/sdk": "^0.27.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.0",
    "yahoo-finance2": "^2.11.0",
    "technicalindicators": "^3.1.0",
    "date-fns": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "concurrently": "^8.2.2"
  }
}
